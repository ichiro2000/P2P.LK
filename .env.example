# Copy this to .env.local and fill in your DO Managed Postgres values.
# In production on App Platform, set the same keys as encrypted env vars.

# DigitalOcean Managed Postgres — Transaction connection pool URL.
# In the DB dashboard: Connection Pools → pick or create a pool with
#   Mode:      Transaction
#   DB:        defaultdb
#   User:      doadmin
# Copy the "Connection String" (URI form) — port is 25061, URL includes
# ?sslmode=require. Looks like:
#   postgresql://doadmin:<password>@<cluster>-pool-do-user-xxxx-0.db.ondigitalocean.com:25061/defaultdb?sslmode=require
DATABASE_URL=

# Shared secret for the protected /api/cron/snapshot endpoint. Only needed
# if you plan to trigger ingest over HTTP; the DO worker doesn't use it.
# Generate one with:  openssl rand -hex 32
CRON_SECRET=
