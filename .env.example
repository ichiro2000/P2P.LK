# Copy this to .env.local and fill in your Postgres connection string.
#
# Local development
#   After your production cluster is live (see DEPLOY.md), go to
#     DO dashboard → Databases → your cluster → Connection Details
#   Add your laptop's IP to the cluster's Trusted Sources, then copy the
#   public "Connection String" (URI form) and paste it below. It will
#   include ?sslmode=require.
#
#   If you prefer not to hit production from your laptop, spin up a free
#   Postgres locally (e.g. `brew install postgresql@16` and
#   `createdb p2p`, then use: postgresql://localhost/p2p ).
#
# Production
#   Nothing to do here. The App Platform deploy auto-injects DATABASE_URL
#   from the attached cluster — .env vars are for local use only.

DATABASE_URL=

# Shared secret for the protected /api/cron/snapshot HTTP endpoint. Not
# needed in normal operation because the ingest worker runs the capture
# loop directly. Generate with:  openssl rand -hex 32
CRON_SECRET=
