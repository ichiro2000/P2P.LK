# Copy this to .env.local and fill in your Supabase values.
# On DigitalOcean App Platform, set the same keys as encrypted env vars.

# Supabase — Transaction pooler connection string (port 6543).
# Find it under: Project → Settings → Database → Connection string → "Transaction pooler"
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Shared secret for the protected /api/cron/snapshot endpoint.
# Generate one with:  openssl rand -hex 32
# Only required in production (the local CLI ingest doesn't need it).
CRON_SECRET=
